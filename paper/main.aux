\@writefile{lof}{\contentsline {figure}{\numberline {16}{\ignorespaces \textbf  {Empirical GRPO group-size ablation} on Qwen3-8B / GSM8K (30 training steps, $G \in \{2, 4, 8, 16, 32\}$). Blue bars show peak reward during training; vermillion bars show last-10 average reward, aggregated across the \texttt  {campaign\_v2\_w2\_*}, \texttt  {campaign\_v2\_w1\_qwen3-8b-base}, and \texttt  {scale\_gsm8k\_qwen3-8b} seeds (for $G{=}8$). Although peak reward rises monotonically up to $G{=}8$ (0.50, 0.75, 0.81, 0.72, 0.45), the last-10 average peaks at $G{=}4$ (0.52). We annotate $G{=}4$ as the \emph  {empirical sweet spot}: higher group sizes trade per-step variance reduction for end-of-training stability.}}{22}{figure.caption.62}\protected@file@percent }
\newlabel{fig:group_size_zvf}{{16}{22}{\textbf {Empirical GRPO group-size ablation} on Qwen3-8B / GSM8K (30 training steps, $G \in \{2, 4, 8, 16, 32\}$). Blue bars show peak reward during training; vermillion bars show last-10 average reward, aggregated across the \texttt {campaign\_v2\_w2\_*}, \texttt {campaign\_v2\_w1\_qwen3-8b-base}, and \texttt {scale\_gsm8k\_qwen3-8b} seeds (for $G{=}8$). Although peak reward rises monotonically up to $G{=}8$ (0.50, 0.75, 0.81, 0.72, 0.45), the last-10 average peaks at $G{=}4$ (0.52). We annotate $G{=}4$ as the \emph {empirical sweet spot}: higher group sizes trade per-step variance reduction for end-of-training stability}{figure.caption.62}{}}
